# postgres database password for the postgres user
# -> replace it with a secure password
POSTGRES_PASSWORD=mysecurepassword

# keycloak admin email
# -> you should not change this value except if you want a separate account for the keycloak admin
KEYCLOAK_ADMIN=admin@chimitheque.fr

# keycloak admin password
# -> replace it with a secure password
KEYCLOAK_ADMIN_PASSWORD=anotherpassword

# chimitheque docker image
# -> do not change this value except for upgrades
CHIMITHEQUE_IMAGE=tbellembois/gochimitheque:latest

# chimitheque URL
# -> set it to the URL of your Chimithèque instance
# devel local
#CHIMITHEQUE_APPURL=https://192.168.1.18:8443
# devel docker
CHIMITHEQUE_APPURL=https://192.168.1.18

# chimitheque debug mode
# -> for debug purposes
CHIMITHEQUE_DEBUG=false

# chimitheque OIDC client secret
# -> replace it with a secure password
CHIMITHEQUE_OIDCCLIENTSECRET=mysupersecret

# chimitheque admin list
# -> comma separated list of emails - non existing accounts will be created
CHIMITHEQUE_ADMINS=bar@foo.com,foo@bar.com
